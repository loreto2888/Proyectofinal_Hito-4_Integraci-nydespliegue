# Variables de entorno para PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=marketplace_user
PGPASSWORD=marketplace_password
PGDATABASE=marketplace

# O bien puedes usar una sola DATABASE_URL
# DATABASE_URL=postgres://marketplace_user:marketplace_password@localhost:5432/marketplace

# Secreto para JWT
JWT_SECRET=mi_super_secreto
